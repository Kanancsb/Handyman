<main class="page page-convert">
  <section class="panel">
    <p class="eyebrow">Convert Files</p>
    <h1>Convert and download your file</h1>
    <p class="lead">
      Upload a file, and the source type will be auto-detected from its extension. Then choose the target format and download the converted result.
    </p>

    <%= form_with url: convert_files_path, method: :post, multipart: true, local: true, class: "convert-form" do %>
      <div class="form-row">
        <div class="file-picker-wrap">
          <button type="button" id="file_picker_button" class="button button-secondary">Upload File</button>
          <span id="file_name_display" class="file-name">No file selected</span>
        </div>
        <%= file_field_tag :file, required: true, id: "file_input", class: "hidden-file-input" %>
      </div>

      <div class="form-row">
        <%= label_tag :source_format, "Source Type" %>
        <%= select_tag :source_format,
                       options_for_select([["Auto detect from file", ""]] + ConvertFilesController::SOURCE_OPTIONS, params[:source_format]),
                       id: "source_format_select" %>
        <p id="source_detect_status" class="auto-detect-note">Pick a file to auto-detect source type.</p>
      </div>

      <div class="form-row">
        <%= label_tag :target_format, "Convert To" %>
        <%= select_tag :target_format, options_for_select(ConvertFilesController::TARGET_OPTIONS, params[:target_format]), required: true %>
      </div>

      <%= submit_tag "Convert and Download", class: "button button-primary" %>
    <% end %>

    <p class="helper-note">
      Tip: for PDF output from images, transparent areas become white.
    </p>
  </section>

  <p class="back-link"><%= link_to "Back to Home", root_path %></p>
</main>

<script>
  (function() {
    var EXTENSION_TO_SOURCE = {
      doc: "word",
      docx: "word",
      odt: "word",
      rtf: "word",
      pdf: "pdf",
      jpg: "jpg",
      jpeg: "jpg",
      png: "png"
    };

    function detectSourceType(fileName) {
      if (!fileName || fileName.indexOf(".") === -1) return "";
      var extension = fileName.split(".").pop().toLowerCase();
      return EXTENSION_TO_SOURCE[extension] || "";
    }

    function bindAutoDetect() {
      var fileInput = document.getElementById("file_input");
      var filePickerButton = document.getElementById("file_picker_button");
      var fileNameDisplay = document.getElementById("file_name_display");
      var sourceSelect = document.getElementById("source_format_select");
      var statusText = document.getElementById("source_detect_status");

      if (!fileInput || !filePickerButton || !fileNameDisplay || !sourceSelect || !statusText || fileInput.dataset.autoDetectBound === "true") return;

      fileInput.dataset.autoDetectBound = "true";
      filePickerButton.addEventListener("click", function() {
        fileInput.click();
      });

      fileInput.addEventListener("change", function() {
        var file = fileInput.files && fileInput.files[0];
        if (!file) {
          fileNameDisplay.textContent = "No file selected";
          sourceSelect.value = "";
          statusText.textContent = "Pick a file to auto-detect source type.";
          return;
        }

        fileNameDisplay.textContent = file.name;
        var detectedSource = detectSourceType(file.name);
        if (detectedSource) {
          sourceSelect.value = detectedSource;
          statusText.textContent = "Source type auto-detected: " + detectedSource.toUpperCase();
        } else {
          sourceSelect.value = "";
          statusText.textContent = "Could not auto-detect this file type. Select a supported source type.";
        }
      });
    }

    document.addEventListener("DOMContentLoaded", bindAutoDetect);
    document.addEventListener("turbolinks:load", bindAutoDetect);
  })();
</script>
