<main class="page page-home">
  <section class="hero">
    <p class="eyebrow">Handyman Daily Tools</p>
    <h1>Welcome to your daily file toolbox</h1>
    <p class="lead">
      This website gives you quick, practical tools for everyday file tasks.
      You can convert Word documents to PDF, turn PDF pages into images,
      and convert JPG/PNG files into icon-ready formats like ICO for social apps.
    </p>
    <%= link_to "Open File Converter", convert_files_path, class: "button button-primary" %>
  </section>

  <section class="features">
    <h2>What you can do here</h2>
    <ul>
      <li>Word (.doc/.docx/.odt/.rtf) to PDF, PNG, or JPG</li>
      <li>PDF to PNG or JPG (first page)</li>
      <li>JPG/PNG to PDF, JPG, PNG, or ICO</li>
    </ul>
  </section>
</main>
